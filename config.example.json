        "seed": 42,
        "num_ctx": 16384,
        "num_predict": 4096,
        "stop": []
      }
    },
    "coder": {
      "model": "qwen3.5:9b",
      "process_timeout": 600,
      "thinking": null,
      "options": {}
    },
    "research": {
      "model": "qwen3.5:9b",
      "process_timeout": 1800,
      "thinking": null,
      "options": {}
    },
    "qa": {
      "model": "qwen3.5:9b",
      "process_timeout": 1200,
      "thinking": null,
      "options": {}

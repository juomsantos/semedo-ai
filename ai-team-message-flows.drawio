<mxfile>
  <diagram name="Message Flows" id="flows">
    <mxGraphModel adaptiveColors="auto">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="f_start" value="Task file dropped in inbox/" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="270" y="40" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="f_orch" value="Orchestrator polls inbox/&lt;br&gt;Decomposes &amp;amp; routes task&lt;br&gt;Parent task moved to processing/" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="245" y="160" width="250" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_type" value="Task type?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="290" width="180" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="f_noncode" value="Research / Claude Code Agent&lt;br&gt;processes task" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="290" width="185" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="f_noncode_out" value="result to outbox/&lt;br&gt;task to validation/" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff0e6;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="575" y="410" width="155" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="f_coder" value="Coder Agent&lt;br&gt;generates code (qwen2.5-coder:7b)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="255" y="430" width="230" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="f_qa_exec" value="QA Agent&lt;br&gt;extracts code, executes via subprocess&lt;br&gt;(30s timeout)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="550" width="240" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_qa_llm" value="QA Agent LLM review&lt;br&gt;qwen3.5:9b | web search&lt;br&gt;outputs VERDICT: PASS / FAIL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="680" width="240" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_pass_d" value="PASS?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="285" y="810" width="170" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="f_retry_d" value="retry_count == 0?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="810" width="185" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="f_retry_task" value="New coder task with&lt;br&gt;full QA FEEDBACK: block&lt;br&gt;(retry_count=1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="545" y="960" width="180" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_failed" value="failed/ ✗&lt;br&gt;failure report written" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="770" y="960" width="160" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_validation" value="validation/&lt;br&gt;subtask awaiting&lt;br&gt;Orchestrator Phase 1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff0e6;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="960" width="185" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="f_orch_phase1" value="Orchestrator Phase 1&lt;br&gt;reads validation/, groups by parent&lt;br&gt;calls validation LLM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="1095" width="215" height="75" as="geometry"/>
        </mxCell>

        <mxCell id="f_dec" value="decision?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="95" y="1235" width="170" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="f_complete" value="outbox/ ✓&lt;br&gt;parent task complete&lt;br&gt;(processing/ to outbox/)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="1390" width="195" height="75" as="geometry"/>
        </mxCell>

        <mxCell id="f_more_work" value="New subtasks dispatched&lt;br&gt;refine / redo / additional_work&lt;br&gt;iteration++ (max 5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="330" y="1250" width="215" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="fe1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="f_start" target="f_orch" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe2" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="f_orch" target="f_type" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe3" value="research / claude-code" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="f_type" target="f_noncode" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe4" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="f_noncode" target="f_noncode_out" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe5" value="code" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="f_type" target="f_coder" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe6" value="chain_to: qa" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="f_coder" target="f_qa_exec" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe7" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="f_qa_exec" target="f_qa_llm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe8" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="f_qa_llm" target="f_pass_d" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe9" value="YES" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;fontColor=#82b366;fontStyle=1;" edge="1" source="f_pass_d" target="f_validation" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe10" value="NO" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;fontColor=#b85450;fontStyle=1;" edge="1" source="f_pass_d" target="f_retry_d" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe11" value="YES (first fail)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;fontColor=#d6b656;" edge="1" source="f_retry_d" target="f_retry_task" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe12" value="NO (second fail)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;fontColor=#b85450;" edge="1" source="f_retry_d" target="f_failed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe13" value="retry" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#d6b656;" edge="1" source="f_retry_task" target="f_coder" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe14" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="f_validation" target="f_orch_phase1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe15" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="f_orch_phase1" target="f_dec" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe16" value="complete" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;fontColor=#82b366;fontStyle=1;" edge="1" source="f_dec" target="f_complete" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe17" value="refine / redo / additional_work" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d79b00;fontColor=#d79b00;" edge="1" source="f_dec" target="f_more_work" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe18" value="new subtasks (max 5 iterations)" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#d79b00;fontColor=#d79b00;" edge="1" source="f_more_work" target="f_coder" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="fe19" value="also via validation/ then Phase 1" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#d6b656;" edge="1" source="f_noncode_out" target="f_orch_phase1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
